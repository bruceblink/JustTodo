{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "justtodo",
  "version": "0.0.1",
  "identifier": "top.likanug.justtodo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "justtodo",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/bruceblink/JustTodo/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3QTI3QTU5QTc4NzdGNzIKUldSeWY0ZW5XWHFpaDR1aXlBaUFVdnNySXRwU3RCZjE2Mnk1dk1DWXFHR1g0OHpzZVRDaks3bUgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
