{
  "name": "justtodo",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "author": "[likanug <likanug.g@qq.com>](https://likanug.top)",
  "authorUrl": "https://likanug.top",
  "sponsoringUrl": "https://buymeacoffee.com/bruceblink",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/bruceblink/JustTodo"
  },
  "scaffold": {
    "features": {
      "updater": true,
      "autostart": true
    }
  },
  "scripts": {
    "init:template": "node scripts/init-template.mjs",
    "sync-version": "node scripts/sync-version.cjs",
    "validate-version": "node scripts/validate-version.cjs",
    "release": "node scripts/release.cjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/modals": "^7.17.8",
    "@mantine/notifications": "^7.17.8",
    "@tabler/icons-react": "^2.47.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "clsx": "^2.1.1",
    "i18next": "^23.16.8",
    "phaser": "^3.90.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^9.1.0",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^24.1.3",
    "postcss-preset-mantine": "^1.15.0",
    "prettier": "^3.8.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  }
}
